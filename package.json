# Render.com ustawi PORT automatycznie. Lokalnie możesz użyć 3000.
PORT=3000
NODE_ENV=development

# Thulium
THULIUM_BASE_URL=https://eliteexpertclub.thulium.com
THULIUM_API_USER=CHATGPT
THULIUM_API_PASSWORD=USTAW_W_RENDER_ENV_NIE_W_FRONTENDZIE

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini

# Klucz używany przez wtyczkę Opera GX do komunikacji z backendem.
# Wygeneruj losowy długi ciąg i wpisz ten sam w popup.js wtyczki.
EXTENSION_API_KEY=change-me-long-random-token

# Basic Auth dla webhooków Thulium, jeżeli włączysz autoryzację webhooków w panelu.
WEBHOOK_BASIC_USER=thulium_webhook
WEBHOOK_BASIC_PASSWORD=change-me
